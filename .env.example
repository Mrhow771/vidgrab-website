# ==============================================================================
# VidGrab Website - Environment Variables Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration (website/server/)
# ------------------------------------------------------------------------------
# The port the Express server will listen on. Render sets this automatically.
PORT=3000

# ------------------------------------------------------------------------------
# Frontend Configuration (website/)
# ------------------------------------------------------------------------------
# The base URL of the deployed Express backend server.
# In development, leave blank or set to http://localhost:3000
# In production, set to your Render backend Web Service URL (e.g., https://vidgrab-backend.onrender.com)
VITE_API_BASE_URL=
